<set xmlns:android="http://schemas.android.com"
    android:duration="3000"
    android:fillAfter="true">
    <translate
        android:fromXDelta="200%" android:toXDelta="-150%"
        android:fromYDelta="-200%" android:toYDelta="1000%" />
    <rotate
        android:fromDegrees="0" android:toDegrees="720"
        android:pivotX="50%" android:pivotY="50%" />
</set>
